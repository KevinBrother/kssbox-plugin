#!/usr/bin/env bash
set -euo pipefail

# Follow symlinks to find real script location
REAL_SCRIPT="$(realpath "$0" 2>/dev/null || readlink -f "$0" 2>/dev/null || "$0")"
PLUGIN_ROOT="$(cd "$(dirname "$REAL_SCRIPT")/.." && pwd)"
SKILLS_SRC="${PLUGIN_ROOT}/skills"
SKILLS_DEST="${HOME}/.claude/skills"
EXCLUDE=("test")

usage() {
    echo "Usage: kssbox <command> [skill-name|all]"
    echo ""
    echo "Commands:"
    echo "  add <skill|all>    Install skill(s) to ~/.claude/skills"
    echo "  remove <skill|all> Remove skill(s) from ~/.claude/skills"
    echo "  list               List available skills in this plugin"
    echo ""
    echo "Available skills:"
    for d in "${SKILLS_SRC}"/*/; do
        name="$(basename "$d")"
        [[ " ${EXCLUDE[*]} " =~ " ${name} " ]] && continue
        echo "  - ${name}"
    done
}

cmd_add() {
    local target="$1"
    for d in "${SKILLS_SRC}"/*/; do
        name="$(basename "$d")"
        [[ " ${EXCLUDE[*]} " =~ " ${name} " ]] && continue
        [[ "$target" != "all" && "$target" != "$name" ]] && continue
        dest="${SKILLS_DEST}/${name}"
        if [ -L "$dest" ]; then
            echo "⟳ ${name} (already linked, skipping)"
        elif [ -e "$dest" ]; then
            echo "✘ ${name} (exists but is not a symlink, skipping)"
        else
            ln -s "${d%/}" "$dest"
            echo "✔ ${name} → ${dest}"
        fi
    done
}

cmd_remove() {
    local target="$1"
    for d in "${SKILLS_SRC}"/*/; do
        name="$(basename "$d")"
        [[ " ${EXCLUDE[*]} " =~ " ${name} " ]] && continue
        [[ "$target" != "all" && "$target" != "$name" ]] && continue
        dest="${SKILLS_DEST}/${name}"
        if [ -L "$dest" ]; then
            rm "$dest"
            echo "✔ removed ${name}"
        else
            echo "⟳ ${name} (not installed, skipping)"
        fi
    done
}

cmd_list() {
    for d in "${SKILLS_SRC}"/*/; do
        name="$(basename "$d")"
        [[ " ${EXCLUDE[*]} " =~ " ${name} " ]] && continue
        dest="${SKILLS_DEST}/${name}"
        if [ -L "$dest" ]; then
            echo "✔ ${name} (installed)"
        else
            echo "  ${name}"
        fi
    done
}

if [ $# -lt 1 ]; then
    usage; exit 0
fi

case "$1" in
    add)
        [ $# -lt 2 ] && { echo "Usage: kssbox add <skill|all>"; exit 1; }
        cmd_add "$2"
        ;;
    remove|rm)
        [ $# -lt 2 ] && { echo "Usage: kssbox remove <skill|all>"; exit 1; }
        cmd_remove "$2"
        ;;
    list|ls)
        cmd_list
        ;;
    *)
        usage; exit 1
        ;;
esac
